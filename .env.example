# Server
NODE_ENV=production
PORT=3001

# Logging
LOG_LEVEL=info

# Database
SQLITE_DB_PATH=./data/app.sqlite

# CORS - JSON array of allowed origins
CORS_ORIGIN_ALLOWLIST=["https://yourdomain.com"]

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Backups
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=7
